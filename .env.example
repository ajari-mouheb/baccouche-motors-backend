# Gateway
PORT=4000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
FRONTEND_URL=http://localhost:3001

# RabbitMQ (when running locally with Docker: amqp://localhost:5672)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Database (per-microservice when running locally, not in Docker)
# Each microservice uses its own DB_NAME
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Auth microservice
# DB_NAME=baccouche_auth

# Cars microservice
# DB_NAME=baccouche_cars

# News microservice
# DB_NAME=baccouche_news

# Test-drives microservice
# DB_NAME=baccouche_test_drives

# Contacts microservice
# DB_NAME=baccouche_contacts

# Optional: SMTP for notifications (password reset, test drive, contact confirmation)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@baccouche-motors.com
